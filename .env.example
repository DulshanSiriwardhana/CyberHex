# CyberHex v1.0 Environment Configuration
# Copy this file to .env.local and update with your values
# DO NOT COMMIT .env.local TO VERSION CONTROL

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URI=mongodb://localhost:27017/cyberhex
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGODB_REPLICA_SET=rs0

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
API_VERSION=v1

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:3000,http://localhost:80
CORS_CREDENTIALS=true

# ============================================
# CLIENT CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_WS_URL=ws://localhost:5000/api/v1/ws

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@cyberhex.com

# ============================================
# AWS/CLOUD CONFIGURATION (Optional)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ============================================
# ERROR TRACKING (Optional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================
# FILE STORAGE
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=3600000

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# ML MODEL CONFIGURATION
# ============================================
MODEL_STORAGE_PATH=./models
MODEL_MAX_SIZE=2147483648
PYTHON_EXECUTABLE=/usr/bin/python3
