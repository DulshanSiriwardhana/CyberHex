# CyberHex Studio — Environment Variables
# Copy to .env and customize

# WebSocket / API backend
VITE_WS_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000/api/v1

# AI Inference
VITE_TF_BACKEND=webgpu
VITE_ONNX_WASM_PATH=/models/onnx-wasm.wasm
VITE_MAX_MODEL_CACHE_SIZE=3

# Performance
VITE_TARGET_FPS=60
VITE_MAX_RESOLUTION_WIDTH=1920
VITE_MAX_RESOLUTION_HEIGHT=1080
VITE_ENABLE_WORKERS=true
VITE_ENABLE_FRAME_SKIPPING=false

# Features
VITE_ENABLE_TRAINING=false
VITE_ENABLE_PLUGINS=true
VITE_ENABLE_WEBRTC=true
VITE_ENABLE_SCREEN_SHARE=true

# Security
VITE_ENCRYPT_MEDIA=false
VITE_SANDBOX_PLUGINS=true
VITE_REQUIRE_AUTH=false

# Analytics (optional)
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=